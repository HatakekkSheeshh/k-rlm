# ─── Backend ──────────────────────────────────────────────────────────────────
# Ollama service URL (in Docker Compose, use service name)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_TIMEOUT=120
DEFAULT_MODEL=phi3:mini

# API
API_PREFIX=/api/v1
# localhost:5173 = Vite dev; localhost:3000 = optional prod preview
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
